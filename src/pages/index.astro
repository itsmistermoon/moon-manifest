          </div>
        </section>

      </main>
    </div>
  </div>

  <footer class="max-w-6xl mx-auto px-6 py-12 mt-12 border-t border-dark-border text-center md:text-left">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-gray-500 text-sm">Temuco, Chile · Diseñado y construido con Astro & Tailwind</p>
      <div class="flex justify-center md:justify-end gap-6 text-sm font-medium">
        <a href="https://github.com/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ GitHub ]</a>
        <a href="https://www.linkedin.com/in/jparmstrong-dev/" class="text-gray-400 hover:text-white transition-colors">[ LinkedIn ]</a>
        <a href="https://www.behance.net/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ Behance ]</a>
        <a href="https://lile.cl/@itsmistermoon" rel="me" class="text-gray-400 hover:text-white transition-colors">[ Mastodon ]</a>
      </div>
    </div>
  </footer>

<script>
  // Redirigir a /en si el idioma preferido del navegador es inglés
  if (!sessionStorage.getItem('lang-override')) {
    const lang = navigator.language || '';
    if (lang.startsWith('en')) window.location.replace('/en');
  }

  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('#sidebar-nav a');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => link.classList.remove('active'));
        const active = document.querySelector<HTMLAnchorElement>(
          `#sidebar-nav a[href="#${entry.target.id}"]`
        );
        active?.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));

  // Snap de cada sección al múltiplo de 24px — solo Y, X no se toca.
  function snapGrid() {
    const g = 24;
    document.querySelectorAll<HTMLElement>('[data-grid-section]').forEach(sec => {
      sec.style.paddingBottom = '';
      const h = sec.getBoundingClientRect().height;
      const pb = Math.ceil(h / g) * g - h;
      if (pb > 0) sec.style.paddingBottom = pb + 'px';
    });
  }
  // fonts.ready + 300ms cubre el reflow post-Google-Fonts que deshacía el snap.
  const fontsReady = document.fonts?.ready
    ?? new Promise<void>(r => window.addEventListener('load', () => r(), { once: true }));
  fontsReady.then(() => { snapGrid(); setTimeout(snapGrid, 300); });
  window.addEventListener('resize', snapGrid);
</script>
</BaseLayout>
