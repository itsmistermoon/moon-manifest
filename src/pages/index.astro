---
import BaseLayout from '../layouts/BaseLayout.astro';
import MobileNav from '../components/MobileNav.astro';
import Icon from '../components/Icon.astro';

const projects = [
  {
    title: 'Plataforma de Fidelización Serverless',
    subtitle: 'Proyecto final AWS Re/Start 2026 — Sistema en producción',
    description: 'Arquitectura multi-tenant diseñada y desplegada desde cero. Backend en FastAPI/Python sobre AWS Lambda, con frontend en React 19 + TypeScript. Implementación completa de CI/CD con GitHub Actions y gestión de identidad con Cognito.',
    status: 'En Producción',
    tags: ['AWS Lambda', 'FastAPI / Python', 'React 19 + TS', 'GitHub Actions'],
    link: '#',
  },
];

const experience = [
  {
    role: 'Cofundador · Desarrollo & Gestión',
    company: 'Imaquinaria Estudio / Tienda SPA',
    period: '2016 – ACTUALIDAD',
    description: 'Diseño y despliegue de plataforma serverless de fidelización gamificada. Gestión de identidad visual, producción de contenido y canales de venta.',
  },
  {
    role: 'Cofundador · Administrador Web y Editor',
    company: 'Cuarto Mundo',
    period: '2014 – ACTUALIDAD',
    description: 'Administración y personalización de plataforma WordPress para medio digital de cultura pop. Gestión editorial y producción de contenido desde la fundación.',
  },
  {
    role: 'Administrador de Servidores Web',
    company: 'Lazos S.A.',
    period: '2014 – 2015',
    description: 'Administración de servidores e implementación de funcionalidades para clientes. Replicación de navegación e intranet de CONAF para migración interna.',
  },
];

const designProjects = [
  {
    title: 'iClub — Menú interactivo para restaurantes',
    category: 'UI/UX · App Tablet',
    description: 'Diseño de aplicación de menú para restaurantes en Android. Del mockup inicial al producto final: navegación de carta, pedidos y pagos desde la mesa.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/8d1ae943812871.Y3JvcCw2OTksNTQ3LDMwMiw0OA.jpeg',
    link: 'https://www.behance.net/gallery/43812871/iClub-Interactive-menu-for-restaurants-on-tablets',
  },
  {
    title: 'Imaquinaria Estudio',
    category: 'Identidad Visual',
    description: 'Creación de identidad gráfica y aplicaciones de marca para Imaquinaria Estudio, estudio colaborativo con ilustradores locales, artesanos y productores.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/6f6c3c91696533.Y3JvcCw4MTEsNjM0LDI5NSw4Mg.jpg',
    link: 'https://www.behance.net/gallery/91696533/Imaquinaria-Estudio',
  },
  {
    title: 'Cuarto Mundo',
    category: 'Branding · Logo',
    description: 'Logotipo para Cuarto Mundo, medio especializado en cómics y cultura pop con presencia en prensa, web y redes sociales.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/24f1ea91699409.Y3JvcCw2MjIsNDg2LDY5MCw1NzE.jpg',
    link: 'https://www.behance.net/gallery/91699409/Cuarto-Mundo',
  },
];

const skills = [
  {
    title: 'Cloud & DevOps',
    color: 'accent-blue',
    description: 'AWS (Lambda, API Gateway, DynamoDB, Cognito, CloudFront, S3, SES, CloudWatch, SAM) · GitHub Actions · Docker',
  },
  {
    title: 'Desarrollo',
    color: 'accent-purple',
    description: 'Python · FastAPI · React 19 · TypeScript · HTML/CSS · MySQL · WordPress',
  },
  {
    title: 'IA & Agentes de Código',
    color: 'accent-yellow',
    description: 'Claude Code · OpenAI Codex · Windsurf · Hermes Agent · Ollama · Perplexity',
    full: true,
  },
];
---

<BaseLayout title="Juan Pablo Armstrong · Analista Programador">
  <!-- max-md:pt-[120px] = barra fija de MobileNav (72px, altura propia del componente) + el padding-top original en mobile (py-12, 48px) -->
  <div class="max-w-6xl mx-auto px-6 py-12 lg:py-24 max-lg:pt-[120px]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- Columna Izquierda: Sticky Sidebar -->
      <aside class="lg:col-span-4 lg:min-w-[300px] lg:sticky lg:top-24 lg:h-fit flex flex-col gap-10">
        <!-- Nombre + título + bio -->
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-ink mb-3 leading-[1.1]">
            Juan Pablo<br />Armstrong
          </h1>
          <p class="text-xl text-accent-blue font-medium mb-4">
            Analista Programador · Cloud / AWS
          </p>
          <p class="text-ink-muted leading-relaxed text-base">
            Graduate AWS Re/Start 2026. Proyecto serverless en producción.
            AWS Certified Cloud Practitioner.
          </p>
        </div>

        <!-- Nav estilo brittanychiang — solo desktop -->
        <nav id="sidebar-nav" class="hidden lg:flex flex-col gap-1">
          <a href="#sobre-mi"   class="nav-link"><span class="nav-line"></span><span class="nav-text">Sobre mí</span></a>
          <a href="#proyecto"   class="nav-link"><span class="nav-line"></span><span class="nav-text">Proyecto Destacado</span></a>
          <a href="#experiencia" class="nav-link"><span class="nav-line"></span><span class="nav-text">Experiencia</span></a>
          <a href="#diseno"     class="nav-link"><span class="nav-line"></span><span class="nav-text">Diseño Gráfico</span></a>
          <a href="#stack"      class="nav-link"><span class="nav-line"></span><span class="nav-text">Stack Tecnológico</span></a>
        </nav>

        <!-- Iconos sociales + CV -->
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <a href="mailto:j.p.armstrong@me.com" aria-label="Email" class="relative text-ink-dim hover:text-ink transition-colors before:content-[''] before:absolute before:-inset-2.5">
              <Icon name="mail" class="w-6 h-6" />
            </a>
            <a href="https://github.com/itsmistermoon" target="_blank" rel="noopener" aria-label="GitHub" class="relative text-ink-dim hover:text-ink transition-colors before:content-[''] before:absolute before:-inset-2.5">
              <Icon name="logo-github" class="w-6 h-6" />
            </a>
            <a href="https://www.linkedin.com/in/jparmstrong-dev/" target="_blank" rel="noopener" aria-label="LinkedIn" class="relative text-ink-dim hover:text-ink transition-colors before:content-[''] before:absolute before:-inset-2.5">
              <Icon name="logo-linkedin" class="w-6 h-6" />
            </a>
            <a href="https://www.behance.net/itsmistermoon" target="_blank" rel="noopener" aria-label="Behance" class="relative text-ink-dim hover:text-ink transition-colors before:content-[''] before:absolute before:-inset-2.5">
              <Icon name="logo-behance" class="w-6 h-6" />
            </a>
            <a href="https://lile.cl/@itsmistermoon" target="_blank" rel="me" aria-label="Mastodon" class="relative text-ink-dim hover:text-ink transition-colors before:content-[''] before:absolute before:-inset-2.5">
              <Icon name="logo-mastodon" class="w-6 h-6" />
            </a>
          </div>
          <div class="flex flex-col gap-2 text-sm pt-4 border-t border-dark-border">
            <a href="/cv" class="inline-flex items-center text-ink-muted hover:text-accent-blue transition-colors font-medium">
              Ver CV online
              <Icon name="arrow-right" class="w-4 h-4 ml-2" />
            </a>
            <a href="/cv.pdf" download class="inline-flex items-center text-accent-yellow hover:text-yellow-300 transition-colors font-medium">
              Descargar CV (PDF)
              <Icon name="file-text" class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </aside>

      <MobileNav
        maxWidth="max-w-6xl"
        breakpoint="lg"
        lang={{ es: '/', en: '/en', current: 'es' }}
        homeHref="/"
        parentCrumb={{ label: 'Inicio', href: '/' }}
        crumbDefault="Sobre mí"
        sections={[
          { id: 'sobre-mi', label: 'Sobre mí' },
          { id: 'proyecto', label: 'Proyecto' },
          { id: 'experiencia', label: 'Experiencia' },
          { id: 'diseno', label: 'Diseño Gráfico' },
          { id: 'stack', label: 'Stack' },
        ]}
        links={[
          { href: '/', label: 'Inicio', current: true },
          { href: '/proyecto', label: 'Caso de estudio' },
          { href: '/cv', label: 'CV' },
        ]}
      />

      <!-- Columna Derecha: Contenido -->
      <main class="lg:col-span-8">

        <!-- Sobre mí -->
        <section id="sobre-mi" data-grid-section>
          <h2 class="section-label">Sobre mí</h2>
          <div class="space-y-4 text-ink leading-relaxed text-base">
            <p>
              Analista Programador con experiencia en desarrollo web, administración de servidores y diseño de interfaces.
              Graduate de AWS Re/Start 2026, con proyecto serverless multi-tenant en producción.
              AWS Certified Cloud Practitioner. Autodidacta activo, inglés avanzado (TOEFL 101/120).
            </p>
            <p>
              Vengo del diseño gráfico — trabajé durante años en identidad visual, editorial y UI antes de hacer el cruce al desarrollo.
              Eso me da una perspectiva poco común: entiendo tanto la arquitectura del sistema como la experiencia del usuario final.
            </p>
            <p>
              Actualmente profundizando en el ecosistema AWS e integrando herramientas de IA en flujos de trabajo de desarrollo.
            </p>
          </div>
        </section>

        <!-- Proyecto Destacado -->
        <section id="proyecto" data-grid-section class="pt-24">
          <h2 class="section-label">Proyecto Destacado</h2>
          
          {projects.map((project) => (
            <div class="corner-box corner-yellow">
              <span class="c tl"></span><span class="c tr"></span>
              <span class="c bl"></span><span class="c br"></span>
            <article class="brutalist-card border-0 p-6 md:p-8 group">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
                <div>
                  <h3 class="text-2xl font-display font-bold text-ink mb-2 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-accent-blue font-medium text-sm mb-4">
                    {project.subtitle}
                  </p>
                  <p class="text-ink-muted leading-relaxed">
                    {project.description}
                  </p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mb-6">
                <span class={`px-3 py-1.5 text-xs font-mono font-medium text-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'} bg-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'}/10 border border-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'}/20`}>
                  [ {project.status.toUpperCase()} ]
                </span>
                {project.tags.map((tag) => (
                  <span class="px-3 py-1.5 text-xs font-mono font-medium text-ink-muted bg-dark-bg border border-dark-border">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="flex flex-wrap gap-5 items-center">
                <a href="/proyecto" class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-ink transition-colors duration-200">
                  Ver caso de estudio
                  <Icon name="arrow-right" class="w-4 h-4 ml-2" />
                </a>
                <a href="https://df25g3qcnocfo.cloudfront.net/" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-medium text-accent-yellow hover:text-yellow-300 transition-colors">
                  Ver plataforma
                  <Icon name="external-link" class="w-4 h-4 ml-2" />
                </a>
              </div>
            </article>
            </div>
          ))}
        </section>

        <!-- Experiencia -->
        <section id="experiencia" data-grid-section class="pt-24">
          <h2 class="section-label">Experiencia</h2>
          
          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {experience.map((exp, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-2">
                  <h3 class="text-lg font-semibold text-ink group-hover:text-accent-blue transition-colors">
                    {exp.role}
                  </h3>
                  <span class="text-xs font-mono text-ink-dim mt-1 sm:mt-0">{exp.period}</span>
                </div>
                <p class="text-ink-muted text-sm mb-3">{exp.company}</p>
                <p class="text-ink-muted text-sm leading-relaxed">{exp.description}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Diseño Gráfico -->
        <section id="diseno" data-grid-section class="pt-24">
          <h2 class="section-label">Diseño Gráfico</h2>
          <div class="corner-box mb-8">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            <p class="text-ink-muted leading-relaxed text-sm p-5 border-b border-dark-border">
              Antes de programar, diseñé. Trabajo en identidad visual, diseño editorial e interfaces desde 2014.
              Ese background informa cómo construyo productos: con criterio visual desde el primer commit.
            </p>
            {designProjects.map((project, i) => (
              <a
                href={project.link}
                target="_blank"
                rel="noopener"
                class={`brutalist-card group flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} ${i > 0 ? 'border-t border-dark-border' : ''}`}
              >
                <!-- Imagen -->
                <div class="md:w-2/5 flex-shrink-0 bg-dark-surface overflow-hidden border-b md:border-b-0 border-dark-border" style={i % 2 === 0 ? 'border-right: 1px solid var(--color-dark-border)' : 'border-left: 1px solid var(--color-dark-border)'}>
                  {project.image.startsWith('http') ? (
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover aspect-video" />
                  ) : (
                    <div class="w-full aspect-video flex items-center justify-center">
                      <span class="text-xs font-mono text-gray-600">[ imagen ]</span>
                    </div>
                  )}
                </div>

                <!-- Contenido -->
                <div class="p-6 flex flex-col justify-center">
                  <span class="text-xs font-mono text-ink-dim mb-2 block">{project.category}</span>
                  <h3 class="text-lg font-semibold text-ink mb-3 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed">{project.description}</p>
                </div>
              </a>
            ))}
          </div>

          <a
            href="https://www.behance.net/itsmistermoon"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-ink transition-colors duration-200"
          >
            Ver portfolio completo en Behance
            <Icon name="external-link" class="w-4 h-4 ml-2" />
          </a>
        </section>

        <!-- Stack Tecnológico -->
        <section id="stack" data-grid-section class="pt-24">
          <h2 class="section-label">Stack Tecnológico</h2>
          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {skills.map((skill, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <h4 class="text-ink font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">
                  {skill.title}
                </h4>
                <p class="text-ink-muted text-sm leading-relaxed">{skill.description}</p>
              </div>
            ))}
          </div>
        </section>

      </main>
    </div>
  </div>

  <footer class="max-w-6xl mx-auto px-6 py-12 mt-12 border-t border-dark-border text-center md:text-left">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-ink-dim text-sm">
        Temuco, Chile · Diseñado y construido con Astro & Tailwind · Paleta <a href="https://github.com/tokyo-night/tokyo-night-vscode-theme" target="_blank" rel="noopener" class="hover:text-ink-muted transition-colors">Tokyo Night</a>
      </p>
      <div class="flex flex-wrap justify-center md:justify-end gap-x-6 gap-y-2 text-sm font-medium [&>a]:whitespace-nowrap">
        <a href="https://github.com/itsmistermoon" class="text-ink-muted hover:text-ink transition-colors">[ GitHub ]</a>
        <a href="https://www.linkedin.com/in/jparmstrong-dev/" class="text-ink-muted hover:text-ink transition-colors">[ LinkedIn ]</a>
        <a href="https://www.behance.net/itsmistermoon" class="text-ink-muted hover:text-ink transition-colors">[ Behance ]</a>
        <a href="https://lile.cl/@itsmistermoon" rel="me" class="text-ink-muted hover:text-ink transition-colors">[ Mastodon ]</a>
      </div>
    </div>
  </footer>

<script>
  // Redirigir a /en si el idioma preferido del navegador es inglés
  if (!sessionStorage.getItem('lang-override')) {
    const lang = navigator.language || '';
    if (lang.startsWith('en')) window.location.replace('/en');
  }

  // El pixel-canvas de las cards de Experiencia ahora corre sitewide desde
  // BaseLayout.astro (ver ese archivo) — se sacó de acá para no duplicarlo.

  // El scroll-spy de #sidebar-nav vive en MobileNav.astro (evita un segundo
  // IntersectionObserver haciendo lo mismo — ver comentario en ese componente).

  // Snap de cada sección al múltiplo de 24px — solo Y, X no se toca.
  function snapGrid() {
    const g = 24;
    document.querySelectorAll<HTMLElement>('[data-grid-section]').forEach(sec => {
      sec.style.paddingBottom = '';
      const h = sec.getBoundingClientRect().height;
      const pb = Math.ceil(h / g) * g - h;
      if (pb > 0) sec.style.paddingBottom = pb + 'px';
    });
  }
  // fonts.ready + 300ms cubre el reflow post-Google-Fonts que deshacía el snap.
  const fontsReady = document.fonts?.ready
    ?? new Promise<void>(r => window.addEventListener('load', () => r(), { once: true }));
  fontsReady.then(() => { snapGrid(); setTimeout(snapGrid, 300); });
  window.addEventListener('resize', snapGrid);
</script>
</BaseLayout>
