---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Plataforma de Fidelización Serverless',
    subtitle: 'Proyecto final AWS Re/Start 2026 — Sistema en producción',
    description: 'Arquitectura multi-tenant diseñada y desplegada desde cero. Backend en FastAPI/Python sobre AWS Lambda, con frontend en React 19 + TypeScript. Implementación completa de CI/CD con GitHub Actions y gestión de identidad con Cognito.',
    status: 'En Producción',
    tags: ['AWS Lambda', 'FastAPI / Python', 'React 19 + TS', 'GitHub Actions'],
    link: '#',
  },
];

const experience = [
  {
    role: 'Cofundador · Desarrollo & Gestión',
    company: 'Imaquinaria Estudio / Tienda SPA',
    period: '2016 – ACTUALIDAD',
    description: 'Diseño y despliegue de plataforma serverless de fidelización gamificada. Gestión de identidad visual, producción de contenido y canales de venta.',
  },
  {
    role: 'Cofundador · Administrador Web y Editor',
    company: 'Cuarto Mundo',
    period: '2014 – ACTUALIDAD',
    description: 'Administración y personalización de plataforma WordPress para medio digital de cultura pop. Gestión editorial y producción de contenido desde la fundación.',
  },
  {
    role: 'Administrador de Servidores Web',
    company: 'Lazos S.A.',
    period: '2014 – 2015',
    description: 'Administración de servidores e implementación de funcionalidades para clientes. Replicación de navegación e intranet de CONAF para migración interna.',
  },
];

const designProjects = [
  {
    title: 'iClub — Menú interactivo para restaurantes',
    category: 'UI/UX · App Tablet',
    description: 'Diseño de aplicación de menú para restaurantes en Android. Del mockup inicial al producto final: navegación de carta, pedidos y pagos desde la mesa.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/8d1ae943812871.Y3JvcCw2OTksNTQ3LDMwMiw0OA.jpeg',
    link: 'https://www.behance.net/gallery/43812871/iClub-Interactive-menu-for-restaurants-on-tablets',
  },
  {
    title: 'Imaquinaria Estudio',
    category: 'Identidad Visual',
    description: 'Creación de identidad gráfica y aplicaciones de marca para Imaquinaria Estudio, estudio colaborativo con ilustradores locales, artesanos y productores.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/6f6c3c91696533.Y3JvcCw4MTEsNjM0LDI5NSw4Mg.jpg',
    link: 'https://www.behance.net/gallery/91696533/Imaquinaria-Estudio',
  },
  {
    title: 'Cuarto Mundo',
    category: 'Branding · Logo',
    description: 'Logotipo para Cuarto Mundo, medio especializado en cómics y cultura pop con presencia en prensa, web y redes sociales.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/24f1ea91699409.Y3JvcCw2MjIsNDg2LDY5MCw1NzE.jpg',
    link: 'https://www.behance.net/gallery/91699409/Cuarto-Mundo',
  },
];

const skills = [
  {
    title: 'Cloud & DevOps',
    color: 'accent-blue',
    description: 'AWS (Lambda, API Gateway, DynamoDB, Cognito, CloudFront, S3, SES, CloudWatch, SAM) · GitHub Actions · Docker',
  },
  {
    title: 'Desarrollo',
    color: 'accent-purple',
    description: 'Python · FastAPI · React 19 · TypeScript · HTML/CSS · MySQL · WordPress',
  },
  {
    title: 'IA & Agentes de Código',
    color: 'accent-yellow',
    description: 'Claude Code · OpenAI Codex · Windsurf · Hermes Agent · Ollama · Perplexity',
    full: true,
  },
];
---

<BaseLayout title="Juan Pablo Armstrong · Analista Programador">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      
      <!-- Columna Izquierda: Sticky Sidebar -->
      <aside class="md:col-span-4 md:sticky md:top-12 md:h-fit flex flex-col gap-10">
        <!-- Nombre + título + bio -->
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-3 leading-[1.1]">
            Juan Pablo<br />Armstrong
          </h1>
          <p class="text-xl text-accent-blue font-medium mb-4">
            Analista Programador · Cloud / AWS
          </p>
          <p class="text-gray-400 leading-relaxed text-base">
            Graduate AWS Re/Start 2026. Proyecto serverless en producción.
            Certificación AWS Cloud Practitioner en curso.
          </p>
        </div>

        <!-- Nav estilo brittanychiang — solo desktop -->
        <nav id="sidebar-nav" class="hidden md:flex flex-col gap-1">
          <a href="#sobre-mi"   class="nav-link"><span class="nav-line"></span><span class="nav-text">Sobre mí</span></a>
          <a href="#proyecto"   class="nav-link"><span class="nav-line"></span><span class="nav-text">Proyecto Destacado</span></a>
          <a href="#experiencia" class="nav-link"><span class="nav-line"></span><span class="nav-text">Experiencia</span></a>
          <a href="#diseno"     class="nav-link"><span class="nav-line"></span><span class="nav-text">Diseño Gráfico</span></a>
          <a href="#stack"      class="nav-link"><span class="nav-line"></span><span class="nav-text">Stack Tecnológico</span></a>
        </nav>

        <!-- Iconos sociales + CV -->
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <a href="mailto:j.p.armstrong@me.com" aria-label="Email" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
            <a href="https://github.com/itsmistermoon" target="_blank" rel="noopener" aria-label="GitHub" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/juan-pablo-armstrong-gallegos-04878b411/" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="https://www.behance.net/itsmistermoon" target="_blank" rel="noopener" aria-label="Behance" class="w-6 h-6 flex items-center justify-center border border-current text-xs font-mono font-bold text-gray-500 hover:text-white hover:border-white transition-colors leading-none">Bē</a>
          </div>
          <div class="flex flex-col gap-2 text-sm pt-4 border-t border-dark-border">
            <a href="/cv" class="text-gray-400 hover:text-accent-blue transition-colors font-medium">Ver CV online →</a>
            <a href="/cv.pdf" download class="text-accent-yellow hover:text-yellow-300 transition-colors font-medium">Descargar CV (PDF) ↓</a>
          </div>
        </div>
      </aside>

      <!-- Columna Derecha: Contenido -->
      <main class="md:col-span-8 space-y-24">
        
        <!-- Sobre mí -->
        <section id="sobre-mi">
          <h2 class="section-label">01. Sobre mí</h2>
          <div class="space-y-4 text-gray-300 leading-relaxed text-base">
            <p>
              Analista Programador con experiencia en desarrollo web, administración de servidores y diseño de interfaces.
              Graduate de AWS Re/Start 2026, con proyecto serverless multi-tenant en producción, en proceso de certificación
              AWS Cloud Practitioner. Autodidacta activo, inglés avanzado (TOEFL 101/120).
            </p>
            <p>
              Vengo del diseño gráfico — trabajé durante años en identidad visual, editorial y UI antes de hacer el cruce al desarrollo.
              Eso me da una perspectiva poco común: entiendo tanto la arquitectura del sistema como la experiencia del usuario final.
            </p>
            <p>
              Actualmente profundizando en el ecosistema AWS e integrando herramientas de IA en flujos de trabajo de desarrollo.
            </p>
          </div>
        </section>

        <!-- Proyecto Destacado -->
        <section id="proyecto">
          <h2 class="section-label">02. Proyecto Destacado</h2>
          
          {projects.map((project) => (
            <div class="corner-box">
              <span class="c tl"></span><span class="c tr"></span>
              <span class="c bl"></span><span class="c br"></span>
            <article class="brutalist-card border-0 p-6 md:p-8 group">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
                <div>
                  <h3 class="text-2xl font-display font-bold text-white mb-2 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-accent-blue font-medium text-sm mb-4">
                    {project.subtitle}
                  </p>
                  <p class="text-gray-400 leading-relaxed">
                    {project.description}
                  </p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mb-6">
                <span class={`px-3 py-1.5 text-xs font-mono font-medium text-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'} bg-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'}/10 border border-accent-${project.status === 'En Producción' ? 'yellow' : 'blue'}/20`}>
                  [ {project.status.toUpperCase()} ]
                </span>
                {project.tags.map((tag) => (
                  <span class="px-3 py-1.5 text-xs font-mono font-medium text-gray-300 bg-dark-bg border border-dark-border">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="flex flex-wrap gap-5 items-center">
                <a href="/proyecto" class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-white transition-colors duration-200 group/link">
                  Ver caso de estudio
                  <svg class="w-4 h-4 ml-2 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
                <a href="https://df25g3qcnocfo.cloudfront.net/" target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">
                  Ver plataforma →
                </a>
              </div>
            </article>
            </div>
          ))}
        </section>

        <!-- Experiencia -->
        <section id="experiencia">
          <h2 class="section-label">03. Experiencia</h2>
          
          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {experience.map((exp, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-2">
                  <h3 class="text-lg font-semibold text-white group-hover:text-accent-blue transition-colors">
                    {exp.role}
                  </h3>
                  <span class="text-xs font-mono text-gray-500 mt-1 sm:mt-0">{exp.period}</span>
                </div>
                <p class="text-gray-400 text-sm mb-3">{exp.company}</p>
                <p class="text-gray-400 text-sm leading-relaxed">{exp.description}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Diseño Gráfico -->
        <section id="diseno">
          <h2 class="section-label">05. Diseño Gráfico</h2>
          <p class="text-gray-400 leading-relaxed text-base mb-8">
            Antes de programar, diseñé. Trabajo en identidad visual, diseño editorial e interfaces desde 2014.
            Ese background informa cómo construyo productos: con criterio visual desde el primer commit.
          </p>

          <div class="space-y-6 mb-8">
            {designProjects.map((project, i) => (
              <a
                href={project.link}
                target="_blank"
                rel="noopener"
                class={`brutalist-card corner-box group flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}
              >
                <span class="c tl"></span><span class="c tr"></span>
                <span class="c bl"></span><span class="c br"></span>

                <!-- Imagen -->
                <div class="md:w-2/5 flex-shrink-0 bg-dark-surface overflow-hidden border-b md:border-b-0 border-dark-border" style={i % 2 === 0 ? 'border-right: 1px solid var(--color-dark-border)' : 'border-left: 1px solid var(--color-dark-border)'}>
                  {project.image.startsWith('http') ? (
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover aspect-video" />
                  ) : (
                    <div class="w-full aspect-video flex items-center justify-center">
                      <span class="text-xs font-mono text-gray-600">[ imagen ]</span>
                    </div>
                  )}
                </div>

                <!-- Contenido -->
                <div class="p-6 flex flex-col justify-center">
                  <span class="text-xs font-mono text-gray-500 mb-2 block">{project.category}</span>
                  <h3 class="text-lg font-semibold text-white mb-3 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-gray-400 text-sm leading-relaxed">{project.description}</p>
                </div>
              </a>
            ))}
          </div>

          <a
            href="https://www.behance.net/itsmistermoon"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-white transition-colors duration-200 group"
          >
            Ver portfolio completo en Behance
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </section>

        <!-- Stack Tecnológico -->
        <section id="stack">
          <h2 class="section-label">06. Stack Tecnológico</h2>
          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {skills.map((skill, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <h4 class="text-white font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">
                  {skill.title}
                </h4>
                <p class="text-gray-400 text-sm leading-relaxed">{skill.description}</p>
              </div>
            ))}
          </div>
        </section>

      </main>
    </div>
  </div>

  <footer class="max-w-6xl mx-auto px-6 py-12 mt-12 border-t border-dark-border text-center md:text-left">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-gray-500 text-sm">Temuco, Chile · Diseñado y construido con Astro & Tailwind</p>
      <div class="flex justify-center md:justify-end gap-6 text-sm font-medium">
        <a href="https://github.com/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ GitHub ]</a>
        <a href="https://www.linkedin.com/in/juan-pablo-armstrong-gallegos-04878b411/" class="text-gray-400 hover:text-white transition-colors">[ LinkedIn ]</a>
        <a href="https://www.behance.net/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ Behance ]</a>
      </div>
    </div>
  </footer>

<script>
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('#sidebar-nav a');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => link.classList.remove('active'));
        const active = document.querySelector<HTMLAnchorElement>(
          `#sidebar-nav a[href="#${entry.target.id}"]`
        );
        active?.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));
</script>
</BaseLayout>
