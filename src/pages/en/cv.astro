---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MobileNav from '../../components/MobileNav.astro';
import Icon from '../../components/Icon.astro';

const experience = [
  {
    role: 'Co-founder · Development & Operations',
    company: 'Imaquinaria Estudio / Tienda SPA',
    period: '2016 – Present',
    location: 'Temuco',
    bullets: [
      'Designed and deployed a gamified serverless loyalty platform in production as the final project of the AWS Re/Start 2026 program.',
      'Full stack: Lambda, API Gateway, DynamoDB, Cognito, CloudFront, S3, and SES; backend in FastAPI/Python and frontend in React 19 with TypeScript.',
      'CI/CD with GitHub Actions, multi-tenant architecture.',
      'Brand identity management, content production, and sales channel oversight.',
    ],
  },
  {
    role: 'Co-founder · Web Administrator & Editor',
    company: 'Cuarto Mundo',
    period: '2014 – Present',
    location: 'Chile',
    bullets: [
      'Administration and customization of a WordPress platform for a pop culture digital publication.',
      'Editorial management and content production since founding.',
    ],
  },
  {
    role: 'Web Server Administrator',
    company: 'Lazos S.A.',
    period: '2014 – 2015',
    location: 'Temuco',
    bullets: [
      'Server administration and feature implementation for clients.',
      'Replicated CONAF\'s navigation and intranet for an internal migration project.',
    ],
  },
  {
    role: 'UI Designer · Web Developer',
    company: 'iClub S.A.',
    period: '2011 – 2012',
    location: 'Temuco',
    bullets: [
      'UI design for an Android restaurant ordering app.',
      'Corporate website development.',
    ],
  },
];

const education = [
  {
    title: 'AWS Re/Start — Graduate',
    institution: 'Amazon Web Services',
    period: '2026',
    location: 'Temuco, Chile',
    description: 'Intensive cloud computing program. Official badge. AWS Certified Cloud Practitioner.',
  },
  {
    title: 'Systems Analyst Programmer',
    institution: 'Instituto Santo Tomás',
    period: '2011 – 2015',
    location: 'Temuco',
    description: 'Software development, MySQL databases, networking, and systems administration.',
  },
  {
    title: 'Learn Python From Scratch',
    institution: 'Temuco Lab',
    period: '2025',
    location: '',
    description: 'Programming logic, Python syntax, Google Colab, pandas library.',
  },
  {
    title: 'PrintLab: Innovating in 3D',
    institution: 'Temuco Lab',
    period: '2025',
    location: '',
    description: 'Cloud-based modeling in Onshape, 3D printing, Cura Slicer.',
  },
];

const skills = [
  {
    category: 'Cloud / AWS',
    items: ['Lambda', 'API Gateway', 'DynamoDB', 'Cognito', 'CloudFront', 'S3', 'SES', 'CloudWatch', 'AWS SAM'],
  },
  {
    category: 'Development',
    items: ['Python', 'FastAPI', 'React 19', 'TypeScript', 'HTML / CSS', 'MySQL'],
  },
  {
    category: 'Platforms & Tools',
    items: ['WordPress', 'GitHub Actions', 'VS Code', 'Affinity Suite', 'Adobe CC', 'Docker'],
  },
  {
    category: 'AI & Code Agents',
    items: ['Claude Code', 'OpenAI Codex', 'Hermes Agent', 'Ollama'],
  },
];
---

<BaseLayout title="CV · Juan Pablo Armstrong">
  <MobileNav
    maxWidth="max-w-4xl"
    lang={{ es: '/cv', en: '/en/cv', current: 'en' }}
    homeHref="/en"
    crumbDefault="CV"
    menuLabel="Open menu"
    links={[
      { href: '/en', label: 'Home' },
      { href: '/en/project', label: 'Case study' },
      { href: '/en/cv', label: 'CV', current: true },
    ]}
  />
  <!-- max-md:pt-[120px] = MobileNav's fixed bar (72px, its own component height) + the original mobile padding-top (py-12, 48px) -->
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-24 max-md:pt-[120px]">

    <!-- Header -->
    <header class="mb-12">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-ink mb-2 leading-[1.1]">
            Juan Pablo Armstrong
          </h1>
          <p class="text-xl text-accent-blue font-medium">Systems Analyst · Cloud / AWS</p>
        </div>
        <a href="/en/cv.pdf" download class="inline-flex items-center px-5 py-2.5 bg-accent-yellow hover:bg-accent-yellow-light text-black font-semibold text-sm transition-colors shrink-0">
          <Icon name="file-text" class="w-4 h-4 mr-2" />
          Download PDF
        </a>
      </div>

      <div class="flex flex-wrap gap-4 text-sm text-ink-muted">
        <span class="flex items-center">
          <Icon name="map-pin" class="w-4 h-4 mr-2 text-ink-dim" />
          Temuco, Chile
        </span>
        <span class="flex items-center">
          <Icon name="phone" class="w-4 h-4 mr-2 text-ink-dim" />
          +569 7850 5946
        </span>
        <a href="mailto:j.p.armstrong@me.com" class="flex items-center hover:text-accent-blue transition-colors">
          <Icon name="mail" class="w-4 h-4 mr-2 text-ink-dim" />
          j.p.armstrong@me.com
        </a>
      </div>
    </header>

    <div class="space-y-12">

      <!-- Profile -->
      <section>
        <h2 class="section-label">Profile</h2>
        <p class="text-ink-muted leading-relaxed text-base">
          Systems Analyst with experience in web development, server administration, and UI design.
          Graduate of the AWS Re/Start 2026 program, with a serverless project in production.
          AWS Certified Cloud Practitioner. Active self-learner, advanced English (TOEFL 101/120), results-oriented.
        </p>
      </section>

      <!-- Featured Project -->
      <section>
        <h2 class="section-label">Featured Project</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
        <div class="brutalist-card border-0 p-6 md:p-8">
          <h3 class="text-2xl font-display font-bold text-ink mb-2">Serverless Loyalty Platform</h3>
          <p class="text-accent-blue font-medium text-sm mb-4">AWS Re/Start 2026 Final Project — live system in production</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">Backend</span>
              <p class="text-ink-muted">FastAPI / Python on AWS Lambda</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">Frontend</span>
              <p class="text-ink-muted">React 19 + TypeScript</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">AWS Services</span>
              <p class="text-ink-muted">Lambda · API Gateway · DynamoDB · Cognito · CloudFront · S3 · SES · CloudWatch</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">DevOps</span>
              <p class="text-ink-muted">GitHub Actions CI/CD · AWS SAM</p>
            </div>
          </div>
          <div class="mt-4">
            <span class="text-ink-dim text-xs font-mono uppercase">Architecture</span>
            <p class="text-ink-muted">Multi-tenant, serverless</p>
          </div>
          <div class="mt-6 pt-4 border-t border-dark-border flex flex-wrap gap-5 items-center">
            <a href="/en/project" class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-ink transition-colors">
              View case study
              <Icon name="arrow-right" class="w-4 h-4 ml-2" />
            </a>
            <a href="https://df25g3qcnocfo.cloudfront.net/" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-medium text-accent-yellow hover:text-yellow-300 transition-colors">
              View platform
              <Icon name="external-link" class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
        </div>
      </section>

      <!-- Experience -->
      <section>
        <h2 class="section-label">Experience</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          {experience.map((exp, i) => (
            <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-ink group-hover:text-accent-blue transition-colors">{exp.role}</h3>
                <span class="text-xs font-mono text-ink-dim mt-1 sm:mt-0">{exp.period}</span>
              </div>
              <p class="text-ink-muted text-sm mb-3">{exp.company}{exp.location && ` · ${exp.location}`}</p>
              <ul class="space-y-1.5">
                {exp.bullets.map((bullet) => (
                  <li class="text-ink-muted text-sm leading-relaxed flex gap-2">
                    <span class="text-dark-border mt-1.5 shrink-0">—</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section>
        <h2 class="section-label">Education</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          {education.map((edu, i) => (
            <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-ink group-hover:text-accent-blue transition-colors">{edu.title}</h3>
                <span class="text-xs font-mono text-ink-dim mt-1 sm:mt-0">{edu.period}</span>
              </div>
              <p class="text-ink-muted text-sm mb-3">{edu.institution}{edu.location && ` · ${edu.location}`}</p>
              <p class="text-ink-muted text-sm leading-relaxed">{edu.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section>
        <h2 class="section-label">Skills</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <span class="c tm"></span><span class="c bm"></span>
          <div class="grid grid-cols-1 md:grid-cols-2">
          {skills.map((skill, i) => {
            const isSecondCol = i % 2 === 1;
            const isThirdRow = i >= 2;
            return (
              <div class={`brutalist-card p-5 border-0 ${isSecondCol ? 'md:border-l border-dark-border' : ''} ${isThirdRow ? 'border-t border-dark-border' : ''} group`}>
                <h4 class="text-ink font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">{skill.category}</h4>
                <div class="flex flex-wrap gap-1.5">
                  {skill.items.map((item) => (
                    <span class="px-2.5 py-1 text-xs font-mono text-ink-muted bg-dark-bg border border-dark-border">{item}</span>
                  ))}
                </div>
              </div>
            );
          })}
          </div>
        </div>
      </section>

      <!-- Language -->
      <section>
        <h2 class="section-label">Language</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="brutalist-card border-0 p-5 group">
            <div class="flex items-center justify-between">
              <div>
                <h4 class="text-ink font-semibold mb-1 group-hover:text-accent-blue transition-colors">English</h4>
                <p class="text-ink-muted text-sm">Advanced — TOEFL 101/120 (2013)</p>
              </div>
              <span class="text-xs font-mono text-accent-yellow border border-accent-yellow/20 px-2 py-1">C1</span>
            </div>
          </div>
        </div>
      </section>

    </div>

  </div>
</BaseLayout>
