---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Serverless Loyalty Platform',
    subtitle: 'AWS Re/Start 2026 Final Project — Live system in production',
    description: 'Multi-tenant architecture designed and deployed from scratch. Backend in FastAPI/Python on AWS Lambda, frontend in React 19 + TypeScript. Full CI/CD with GitHub Actions and identity management with Cognito.',
    status: 'Live',
    tags: ['AWS Lambda', 'FastAPI / Python', 'React 19 + TS', 'GitHub Actions'],
    link: '#',
  },
];

const experience = [
  {
    role: 'Co-founder · Development & Operations',
    company: 'Imaquinaria Estudio / Tienda SPA',
    period: '2016 – PRESENT',
    description: 'Design and deployment of a gamified serverless loyalty platform. Brand identity management, content production, and sales channels.',
  },
  {
    role: 'Co-founder · Web Administrator & Editor',
    company: 'Cuarto Mundo',
    period: '2014 – PRESENT',
    description: 'Administration and customization of a WordPress platform for a pop culture digital publication. Editorial management and content production since founding.',
  },
  {
    role: 'Web Server Administrator',
    company: 'Lazos S.A.',
    period: '2014 – 2015',
    description: 'Server administration and feature implementation for clients. Replicated CONAF\'s navigation and intranet for an internal migration project.',
  },
];

const designProjects = [
  {
    title: 'iClub — Interactive menu for restaurants',
    category: 'UI/UX · Tablet App',
    description: 'Menu app design for restaurants on Android. From initial mockup to final product: menu navigation, orders, and table-side payments.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/8d1ae943812871.Y3JvcCw2OTksNTQ3LDMwMiw0OA.jpeg',
    link: 'https://www.behance.net/gallery/43812871/iClub-Interactive-menu-for-restaurants-on-tablets',
  },
  {
    title: 'Imaquinaria Estudio',
    category: 'Visual Identity',
    description: 'Brand identity and brand applications for Imaquinaria Estudio, a collaborative studio working with local illustrators, craftspeople, and producers.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/6f6c3c91696533.Y3JvcCw4MTEsNjM0LDI5NSw4Mg.jpg',
    link: 'https://www.behance.net/gallery/91696533/Imaquinaria-Estudio',
  },
  {
    title: 'Cuarto Mundo',
    category: 'Branding · Logo',
    description: 'Logo for Cuarto Mundo, a publication specializing in comics and pop culture with presence in print, web, and social media.',
    image: 'https://mir-s3-cdn-cf.behance.net/projects/404/24f1ea91699409.Y3JvcCw2MjIsNDg2LDY5MCw1NzE.jpg',
    link: 'https://www.behance.net/gallery/91699409/Cuarto-Mundo',
  },
];

const skills = [
  {
    title: 'Cloud & DevOps',
    color: 'accent-blue',
    description: 'AWS (Lambda, API Gateway, DynamoDB, Cognito, CloudFront, S3, SES, CloudWatch, SAM) · GitHub Actions · Docker',
  },
  {
    title: 'Development',
    color: 'accent-purple',
    description: 'Python · FastAPI · React 19 · TypeScript · HTML/CSS · MySQL · WordPress',
  },
  {
    title: 'AI & Code Agents',
    color: 'accent-yellow',
    description: 'Claude Code · OpenAI Codex · Hermes Agent · Ollama',
    full: true,
  },
];
---

<BaseLayout title="Juan Pablo Armstrong · Systems Analyst">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">

      <!-- Left Column: Sticky Sidebar -->
      <aside class="md:col-span-4 md:sticky md:top-12 md:h-fit flex flex-col gap-10">
        <!-- Name + title + bio -->
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-3 leading-[1.1]">
            Juan Pablo<br />Armstrong
          </h1>
          <p class="text-xl text-accent-blue font-medium mb-4">
            Systems Analyst · Cloud / AWS
          </p>
          <p class="text-gray-400 leading-relaxed text-base">
            AWS Re/Start 2026 Graduate. Serverless project in production.
            AWS Certified Cloud Practitioner.
          </p>
        </div>

        <!-- Nav -->
        <nav id="sidebar-nav" class="hidden md:flex flex-col gap-1">
          <a href="#about"      class="nav-link"><span class="nav-line"></span><span class="nav-text">About</span></a>
          <a href="#project"    class="nav-link"><span class="nav-line"></span><span class="nav-text">Featured Project</span></a>
          <a href="#experience" class="nav-link"><span class="nav-line"></span><span class="nav-text">Experience</span></a>
          <a href="#design"     class="nav-link"><span class="nav-line"></span><span class="nav-text">Graphic Design</span></a>
          <a href="#stack"      class="nav-link"><span class="nav-line"></span><span class="nav-text">Tech Stack</span></a>
        </nav>

        <!-- Social icons + CV -->
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <a href="mailto:j.p.armstrong@me.com" aria-label="Email" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
            <a href="https://github.com/itsmistermoon" target="_blank" rel="noopener" aria-label="GitHub" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/jparmstrong-dev/" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="https://www.behance.net/itsmistermoon" target="_blank" rel="noopener" aria-label="Behance" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M4.654 3c.461 0 .887.035 1.278.14.39.07.711.216.996.391s.497.426.641.747c.14.32.216.711.216 1.137 0 .496-.106.922-.356 1.242-.215.32-.566.606-.997.817.606.176 1.067.496 1.348.922s.461.957.461 1.563c0 .496-.105.922-.285 1.278a2.3 2.3 0 0 1-.782.887c-.32.215-.711.39-1.137.496a5.3 5.3 0 0 1-1.278.176L0 12.803V3zm-.285 3.978c.39 0 .71-.105.957-.285.246-.18.355-.497.355-.887 0-.216-.035-.426-.105-.567a1 1 0 0 0-.32-.355 1.8 1.8 0 0 0-.461-.176c-.176-.035-.356-.035-.567-.035H2.17v2.31c0-.005 2.2-.005 2.2-.005zm.105 4.193c.215 0 .426-.035.606-.07.176-.035.356-.106.496-.216s.25-.215.356-.39c.07-.176.14-.391.14-.641 0-.496-.14-.852-.426-1.102-.285-.215-.676-.32-1.137-.32H2.17v2.734h2.305zm6.858-.035q.428.427 1.278.426c.39 0 .746-.106 1.032-.286q.426-.32.53-.64h1.74c-.286.851-.712 1.457-1.278 1.848-.566.355-1.243.566-2.06.566a4.1 4.1 0 0 1-1.527-.285 2.8 2.8 0 0 1-1.137-.782 2.85 2.85 0 0 1-.712-1.172c-.175-.461-.25-.957-.25-1.528 0-.531.07-1.032.25-1.493.18-.46.426-.852.747-1.207.32-.32.711-.606 1.137-.782a4 4 0 0 1 1.493-.285c.606 0 1.137.105 1.598.355.46.25.817.532 1.102.958.285.39.496.851.641 1.348.07.496.105.996.07 1.563h-5.15c0 .58.21 1.11.496 1.396m2.24-3.732c-.25-.25-.642-.391-1.103-.391-.32 0-.566.07-.781.176s-.356.25-.496.39a.96.96 0 0 0-.25.497c-.036.175-.07.32-.07.46h3.196c-.07-.526-.25-.882-.497-1.132zm-3.127-3.728h3.978v.957h-3.978z"/></svg>
            </a>
            <a href="https://lile.cl/@itsmistermoon" target="_blank" rel="me" aria-label="Mastodon" class="text-gray-500 hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a4 4 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522q0-1.288.66-2.046c.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764q.662.757.661 2.046z"/></svg>
            </a>
          </div>
          <div class="flex flex-col gap-2 text-sm pt-4 border-t border-dark-border">
            <a href="/en/cv" class="text-gray-400 hover:text-accent-blue transition-colors font-medium">View CV online →</a>
            <a href="/en/cv.pdf" download class="text-accent-yellow hover:text-yellow-300 transition-colors font-medium">Download CV (PDF) ↓</a>
          </div>
          <div class="flex gap-3 text-xs font-mono pt-2">
            <a href="/" class="text-gray-500 hover:text-gray-300 transition-colors" id="lang-es">ES</a>
            <span class="text-dark-border">|</span>
            <span class="text-accent-yellow">EN</span>
          </div>
        </div>
      </aside>

      <!-- Mobile Nav (Top Right FAB) -->
      <div class="md:hidden fixed top-6 right-6 z-50 flex flex-col items-end gap-3">
        <button id="mobile-nav-toggle" aria-label="Toggle menu" class="w-12 h-12 bg-accent-blue text-dark-bg font-bold flex items-center justify-center text-xl shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all z-50 outline-none focus-visible:ring-2 focus-visible:ring-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
        <div id="mobile-nav-menu" class="flex flex-col gap-2 items-end origin-top-right opacity-0 scale-95 pointer-events-none transition-all duration-200 ease-out">
          <a href="#about" class="mobile-nav-link bg-dark-bg border border-dark-border px-4 py-2 text-sm font-mono text-white shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:bg-accent-blue hover:text-black focus-visible:bg-accent-blue focus-visible:text-black outline-none transition-colors">01. About</a>
          <a href="#project" class="mobile-nav-link bg-dark-bg border border-dark-border px-4 py-2 text-sm font-mono text-white shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:bg-accent-purple hover:text-black focus-visible:bg-accent-purple focus-visible:text-black outline-none transition-colors">02. Project</a>
          <a href="#experience" class="mobile-nav-link bg-dark-bg border border-dark-border px-4 py-2 text-sm font-mono text-white shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:bg-accent-yellow hover:text-black focus-visible:bg-accent-yellow focus-visible:text-black outline-none transition-colors">03. Experience</a>
          <a href="#design" class="mobile-nav-link bg-dark-bg border border-dark-border px-4 py-2 text-sm font-mono text-white shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:bg-accent-blue hover:text-black focus-visible:bg-accent-blue focus-visible:text-black outline-none transition-colors">04. Design</a>
          <a href="#stack" class="mobile-nav-link bg-dark-bg border border-dark-border px-4 py-2 text-sm font-mono text-white shadow-[4px_4px_0_0_rgba(255,255,255,1)] hover:bg-accent-purple hover:text-black focus-visible:bg-accent-purple focus-visible:text-black outline-none transition-colors">05. Stack</a>
        </div>
      </div>

      <!-- Right Column: Content -->
      <main class="md:col-span-8">

        <!-- About -->
        <section id="about" data-grid-section>
          <h2 class="section-label">01. About</h2>
          <div class="space-y-4 text-gray-300 leading-relaxed text-base">
            <p>
              Systems Analyst with experience in web development, server administration, and UI design.
              AWS Re/Start 2026 Graduate, with a multi-tenant serverless project in production.
              AWS Certified Cloud Practitioner. Active self-learner, advanced English (TOEFL 101/120).
            </p>
            <p>
              I come from graphic design — I spent years in visual identity, editorial, and UI before crossing into development.
              That gives me an uncommon perspective: I understand both system architecture and the end-user experience.
            </p>
            <p>
              Currently deepening expertise in the AWS ecosystem and integrating AI tools into development workflows.
            </p>
          </div>
        </section>

        <!-- Featured Project -->
        <section id="project" data-grid-section class="pt-24">
          <h2 class="section-label">02. Featured Project</h2>

          {projects.map((project) => (
            <div class="corner-box corner-yellow">
              <span class="c tl"></span><span class="c tr"></span>
              <span class="c bl"></span><span class="c br"></span>
            <article class="brutalist-card border-0 p-6 md:p-8 group">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
                <div>
                  <h3 class="text-2xl font-display font-bold text-white mb-2 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-accent-blue font-medium text-sm mb-4">
                    {project.subtitle}
                  </p>
                  <p class="text-gray-400 leading-relaxed">
                    {project.description}
                  </p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mb-6">
                <span class="px-3 py-1.5 text-xs font-mono font-medium text-accent-yellow bg-accent-yellow/10 border border-accent-yellow/20">
                  [ {project.status.toUpperCase()} ]
                </span>
                {project.tags.map((tag) => (
                  <span class="px-3 py-1.5 text-xs font-mono font-medium text-gray-300 bg-dark-bg border border-dark-border">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="flex flex-wrap gap-5 items-center">
                <a href="/en/project" class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-white transition-colors duration-200 group/link">
                  View case study
                  <svg class="w-4 h-4 ml-2 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
                <a href="https://df25g3qcnocfo.cloudfront.net/" target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">
                  View platform →
                </a>
              </div>
            </article>
            </div>
          ))}
        </section>

        <!-- Experience -->
        <section id="experience" data-grid-section class="pt-24">
          <h2 class="section-label">03. Experience</h2>

          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {experience.map((exp, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-2">
                  <h3 class="text-lg font-semibold text-white group-hover:text-accent-blue transition-colors">
                    {exp.role}
                  </h3>
                  <span class="text-xs font-mono text-gray-500 mt-1 sm:mt-0">{exp.period}</span>
                </div>
                <p class="text-gray-400 text-sm mb-3">{exp.company}</p>
                <p class="text-gray-400 text-sm leading-relaxed">{exp.description}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Graphic Design -->
        <section id="design" data-grid-section class="pt-24">
          <h2 class="section-label">05. Graphic Design</h2>
          <div class="corner-box mb-8">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            <p class="text-gray-400 leading-relaxed text-sm p-5 border-b border-dark-border">
              Before coding, I designed. I've worked in visual identity, editorial design, and interfaces since 2014.
              That background informs how I build products: with visual judgment from the first commit.
            </p>
            {designProjects.map((project, i) => (
              <a
                href={project.link}
                target="_blank"
                rel="noopener"
                class={`brutalist-card group flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} ${i > 0 ? 'border-t border-dark-border' : ''}`}
              >
                <div class="md:w-2/5 flex-shrink-0 bg-dark-surface overflow-hidden border-b md:border-b-0 border-dark-border" style={i % 2 === 0 ? 'border-right: 1px solid var(--color-dark-border)' : 'border-left: 1px solid var(--color-dark-border)'}>
                  {project.image.startsWith('http') ? (
                    <img src={project.image} alt={project.title} class="w-full h-full object-cover aspect-video" />
                  ) : (
                    <div class="w-full aspect-video flex items-center justify-center">
                      <span class="text-xs font-mono text-gray-600">[ image ]</span>
                    </div>
                  )}
                </div>
                <div class="p-6 flex flex-col justify-center">
                  <span class="text-xs font-mono text-gray-500 mb-2 block">{project.category}</span>
                  <h3 class="text-lg font-semibold text-white mb-3 group-hover:text-accent-blue transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-gray-400 text-sm leading-relaxed">{project.description}</p>
                </div>
              </a>
            ))}
          </div>

          <a
            href="https://www.behance.net/itsmistermoon"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-white transition-colors duration-200 group"
          >
            View full portfolio on Behance
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </section>

        <!-- Tech Stack -->
        <section id="stack" data-grid-section class="pt-24">
          <h2 class="section-label">06. Tech Stack</h2>
          <div class="corner-box">
            <span class="c tl"></span><span class="c tr"></span>
            <span class="c bl"></span><span class="c br"></span>
            {skills.map((skill, i) => (
              <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
                <h4 class="text-white font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">
                  {skill.title}
                </h4>
                <p class="text-gray-400 text-sm leading-relaxed">{skill.description}</p>
              </div>
            ))}
          </div>
        </section>

      </main>
    </div>
  </div>

  <footer class="max-w-6xl mx-auto px-6 py-12 mt-12 border-t border-dark-border text-center md:text-left">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-gray-500 text-sm">Temuco, Chile · Designed and built with Astro & Tailwind</p>
      <div class="flex justify-center md:justify-end gap-6 text-sm font-medium">
        <a href="https://github.com/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ GitHub ]</a>
        <a href="https://www.linkedin.com/in/jparmstrong-dev/" class="text-gray-400 hover:text-white transition-colors">[ LinkedIn ]</a>
        <a href="https://www.behance.net/itsmistermoon" class="text-gray-400 hover:text-white transition-colors">[ Behance ]</a>
        <a href="https://lile.cl/@itsmistermoon" rel="me" class="text-gray-400 hover:text-white transition-colors">[ Mastodon ]</a>
      </div>
    </div>
  </footer>

<script>
  // Mark that the user chose English manually — skip auto-redirect on ES root
  sessionStorage.setItem('lang-override', 'en');

  // Mobile Nav Toggle Logic
  const mobileNavToggle = document.getElementById('mobile-nav-toggle');
  const mobileNavMenu = document.getElementById('mobile-nav-menu');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMobileNav() {
    const isOpen = mobileNavMenu?.classList.contains('opacity-100');
    if (isOpen) {
      mobileNavMenu?.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
      mobileNavMenu?.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
    } else {
      mobileNavMenu?.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
      mobileNavMenu?.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
    }
  }

  mobileNavToggle?.addEventListener('click', toggleMobileNav);
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', toggleMobileNav);
  });

  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('#sidebar-nav a');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => link.classList.remove('active'));
        const active = document.querySelector<HTMLAnchorElement>(
          `#sidebar-nav a[href="#${entry.target.id}"]`
        );
        active?.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));

  function snapGrid() {
    const g = 24;
    document.querySelectorAll<HTMLElement>('[data-grid-section]').forEach(sec => {
      sec.style.paddingBottom = '';
      const h = sec.getBoundingClientRect().height;
      const pb = Math.ceil(h / g) * g - h;
      if (pb > 0) sec.style.paddingBottom = pb + 'px';
    });
  }
  const fontsReady = document.fonts?.ready
    ?? new Promise<void>(r => window.addEventListener('load', () => r(), { once: true }));
  fontsReady.then(() => { snapGrid(); setTimeout(snapGrid, 300); });
  window.addEventListener('resize', snapGrid);
</script>
</BaseLayout>
