---
import BaseLayout from '../../layouts/BaseLayout.astro';

const platformUrl = 'https://df25g3qcnocfo.cloudfront.net/';

const levels = [
  { name: 'Rōnin',    multiplier: '×1.0' },
  { name: 'Samurai',  multiplier: '×1.3' },
  { name: 'Hatamoto', multiplier: '×1.7' },
  { name: 'Daimyō',   multiplier: '×2.0' },
];

const decisions = [
  {
    number: '01',
    title: 'DynamoDB single-table',
    body: '10+ entities in one table. PK/SK keys modeled by access pattern, not by entity. Every query includes tenant_id: physical isolation between merchants with no additional infrastructure.',
  },
  {
    number: '02',
    title: 'Multi-tenant from day one',
    body: 'Single-tenant deployed, multi-tenant ready pattern. Adding a second merchant means registering it in the table — no business logic changes. The architecture doesn\'t limit growth.',
  },
  {
    number: '03',
    title: 'Pipeline with manual gate',
    body: 'GitHub Actions deploys to staging automatically. Production requires manual approval. Five bugs caught in staging before reaching the live system.',
  },
];

const stack = [
  'FastAPI', 'Python 3.13', 'React 19', 'TypeScript', 'Mangum',
  'AWS Lambda', 'API Gateway', 'DynamoDB', 'Cognito',
  'CloudFront', 'S3', 'SES', 'CloudWatch', 'SSM',
  'AWS SAM', 'GitHub Actions',
];
---

<BaseLayout title="DŌJŌ · Case Study · Juan Pablo Armstrong">
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-20">

    <!-- Header -->
    <header class="mb-12">
      <p class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-6">
        Case study · AWS Re/Start 2026 · Final project
      </p>
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-2 leading-[1.1]">DŌJŌ</h1>
          <p class="text-xl text-accent-blue font-medium">Gamified serverless loyalty platform</p>
        </div>
        <a href={platformUrl} target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2.5 bg-accent-yellow hover:bg-yellow-500 text-black font-semibold text-sm transition-colors shrink-0">
          View platform
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        </a>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-mono font-medium text-accent-yellow bg-accent-yellow/10 border border-accent-yellow/20">[ LIVE ]</span>
        <span class="px-3 py-1 text-xs font-mono text-gray-400 border border-dark-border">Phases 0 → 8 complete</span>
        <span class="px-3 py-1 text-xs font-mono text-gray-400 border border-dark-border">16 ADRs documented</span>
      </div>
    </header>

    <div class="space-y-12">

      <!-- Problem -->
      <section>
        <h2 class="section-label">The problem</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="grid grid-cols-1 md:grid-cols-3">
            <div class="brutalist-card p-5 border-0">
              <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-2">The client</span>
              <p class="text-gray-300 text-sm leading-relaxed">Imaquinaria — a physical store selling manga, anime, and Japanese culture in Temuco, Chile.</p>
            </div>
            <div class="brutalist-card p-5 border-0 md:border-l border-dark-border border-t md:border-t-0">
              <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-2">The need</span>
              <p class="text-gray-300 text-sm leading-relaxed">No loyalty system: no incentive to return, no purchase history, no customer data.</p>
            </div>
            <div class="brutalist-card p-5 border-0 md:border-l border-dark-border border-t md:border-t-0">
              <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-2">Dual purpose</span>
              <p class="text-gray-300 text-sm leading-relaxed">A real system for Imaquinaria + a cloud technical portfolio for employability.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Solution -->
      <section>
        <h2 class="section-label">The solution</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <span class="c tm"></span><span class="c bm"></span>
          <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="brutalist-card p-6 border-0 group">
              <h3 class="text-white font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">Customer portal</h3>
              <ul class="space-y-1.5">
                {['Sign up and sign in', 'Check points, level, and XP', 'Purchase history', 'Redeem rewards', 'Active missions (stamp cards)'].map(item => (
                  <li class="text-gray-400 text-sm flex gap-2">
                    <span class="text-dark-border mt-1.5 shrink-0">—</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="brutalist-card p-6 border-0 md:border-l border-dark-border border-t md:border-t-0 group">
              <h3 class="text-white font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">Admin panel</h3>
              <ul class="space-y-1.5">
                {['Register purchases at POS', 'Manage rewards', 'Manage missions', 'Customer statistics', 'Level and multiplier configuration'].map(item => (
                  <li class="text-gray-400 text-sm flex gap-2">
                    <span class="text-dark-border mt-1.5 shrink-0">—</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Architecture -->
      <section>
        <h2 class="section-label">Architecture</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="brutalist-card p-5 border-0">
            <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-3">Zone 1 — Edge / Public</span>
            <div class="flex flex-wrap gap-2">
              {['CloudFront (CDN, SPA routing)', 'S3 Bucket (React static build)', 'HTTPS via Route 53'].map(item => (
                <span class="px-2.5 py-1 text-xs font-mono text-gray-300 bg-dark-bg border border-dark-border">{item}</span>
              ))}
            </div>
          </div>
          <div class="brutalist-card p-5 border-0 border-t border-dark-border">
            <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-3">Zone 2 — Authentication</span>
            <div class="flex flex-wrap gap-2">
              {['API Gateway (HTTP API)', 'Cognito User Pool', 'JWT validation on every request'].map(item => (
                <span class="px-2.5 py-1 text-xs font-mono text-gray-300 bg-dark-bg border border-dark-border">{item}</span>
              ))}
            </div>
          </div>
          <div class="brutalist-card p-5 border-0 border-t border-dark-border">
            <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-3">Zone 3 — Compute / Private</span>
            <div class="flex flex-wrap gap-2">
              {['AWS Lambda (FastAPI + Mangum)', 'DynamoDB single-table (by tenant_id)', 'SSM · SES · CloudWatch'].map(item => (
                <span class="px-2.5 py-1 text-xs font-mono text-gray-300 bg-dark-bg border border-dark-border">{item}</span>
              ))}
            </div>
          </div>
          <div class="brutalist-card p-5 border-0 border-t border-dark-border">
            <span class="text-gray-500 text-xs font-mono uppercase tracking-wider block mb-3">CI/CD</span>
            <p class="text-gray-300 text-sm">GitHub Actions — deploys frontend (S3 / CloudFront) and backend (<code class="font-mono text-xs">sam deploy</code>). Manual gate required before production.</p>
          </div>
        </div>
      </section>

      <!-- Technical decisions -->
      <section>
        <h2 class="section-label">Key technical decisions</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          {decisions.map((d, i) => (
            <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
              <div class="flex gap-4 items-start">
                <span class="text-3xl font-display font-bold text-dark-border shrink-0 leading-none mt-0.5">{d.number}</span>
                <div>
                  <h3 class="text-white font-semibold mb-2 text-base group-hover:text-accent-blue transition-colors">{d.title}</h3>
                  <p class="text-gray-400 text-sm leading-relaxed">{d.body}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Loyalty program -->
      <section>
        <h2 class="section-label">Loyalty program</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="brutalist-card p-6 border-0">
            <h3 class="text-white font-semibold mb-1 text-base">The Imaquinaria Bushidō</h3>
            <p class="text-gray-500 text-xs font-mono mb-5">Level system with points multipliers</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
              {levels.map(level => (
                <div class="border border-dark-border p-3 text-center">
                  <span class="text-accent-yellow text-xs font-mono block mb-1">{level.multiplier}</span>
                  <span class="text-gray-300 text-sm font-medium">{level.name}</span>
                </div>
              ))}
            </div>
            <div class="flex flex-wrap gap-2 pt-4 border-t border-dark-border">
              {['Premium Kamon tier', 'Digital stamp cards', '16 ADRs documented'].map(tag => (
                <span class="px-2.5 py-1 text-xs font-mono text-gray-300 bg-dark-bg border border-dark-border">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Full stack -->
      <section>
        <h2 class="section-label">Full stack</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="brutalist-card p-5 border-0">
            <div class="flex flex-wrap gap-1.5">
              {stack.map(item => (
                <span class="px-2.5 py-1 text-xs font-mono text-gray-300 bg-dark-bg border border-dark-border">{item}</span>
              ))}
            </div>
          </div>
        </div>
      </section>

    </div>

    <footer class="mt-16 pt-8 border-t border-dark-border">
      <div class="flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center">
        <a href="/en" class="text-sm text-gray-500 hover:text-accent-blue transition-colors">← Back to portfolio</a>
        <a href={platformUrl} target="_blank" rel="noopener" class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-white transition-colors">
          View live platform
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        </a>
      </div>
    </footer>

  </div>
</BaseLayout>
