---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = 'Analista Programador · Cloud / AWS · Temuco, Chile',
  image = '/og-image.png'
} = Astro.props;

const pathname = Astro.url.pathname;
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');
const currentLang = isEnglish ? 'en' : 'es';
const alternateLang = isEnglish ? 'es' : 'en';

const site = Astro.site ? new URL(Astro.site).origin : 'https://jparmstrong.vercel.app';
const buildUrl = (path: string) => new URL(path, site).toString();

// Canonical URLs should be normalized to avoid duplicate content
const normalizedPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;
const canonicalURL = buildUrl(normalizedPath);

// Generate alternate language paths safely
const alternatePath = isEnglish 
  ? pathname.replace(/^\/en(\/|$)/, '/') 
  : `/en${pathname === '/' ? '' : pathname}`;
const alternateURL = buildUrl(alternatePath);
const imageUrl = buildUrl(image);
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@125,600;125,700;125,800&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&display=swap" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO & Open Graph -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link rel="alternate" hreflang={currentLang} href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={isEnglish ? alternateURL : canonicalURL} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body class="min-h-screen">
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  // Pixel-grid hover: grilla animada sobre toda .brutalist-card, sitewide. Vive acá
  // (BaseLayout) para aplicarse a todas las páginas, no solo index.astro. Inyecta el
  // <canvas> automáticamente — ninguna card lo trae ya en el markup.
  document.querySelectorAll<HTMLElement>('.brutalist-card').forEach((card) => {
    let canvas = card.querySelector<HTMLCanvasElement>('.proto-pixel-canvas');
    if (!canvas) {
      canvas = document.createElement('canvas');
      canvas.className = 'proto-pixel-canvas absolute inset-0 -z-10 pointer-events-none';
      canvas.setAttribute('aria-hidden', 'true');
      card.appendChild(canvas);
    }
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const cell = 6;
    const dpr = window.devicePixelRatio || 1;
    let w = 0, h = 0, cols = 0, rows = 0, mx = -9999, my = -9999, raf = 0;
    let phases: number[] = [];

    function resize() {
      const r = card.getBoundingClientRect();
      w = r.width; h = r.height;
      cols = Math.ceil(w / cell); rows = Math.ceil(h / cell);
      canvas!.width = w * dpr; canvas!.height = h * dpr;
      canvas!.style.width = w + 'px'; canvas!.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      phases = Array.from({ length: cols * rows }, () => Math.random() * Math.PI * 2);
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, w, h);
      const radius = 260;
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const cx = x * cell + cell / 2, cy = y * cell + cell / 2;
          const dist = Math.hypot(cx - mx, cy - my);
          const proximity = Math.max(0, 1 - dist / radius);
          if (proximity <= 0) continue;
          const flicker = (Math.sin(t * 0.002 + phases[y * cols + x]) + 1) / 2;
          const alpha = proximity * (0.03 + flicker * 0.09);
          if (alpha > 0.006) {
            ctx!.fillStyle = `rgba(192,202,245,${alpha})`; // #c0caf5
            ctx!.fillRect(x * cell, y * cell, cell - 1, cell - 1);
          }
        }
      }
      raf = requestAnimationFrame(draw);
    }

    card.addEventListener('mouseenter', () => { resize(); raf = requestAnimationFrame(draw); });
    card.addEventListener('mousemove', (e) => {
      const r = card.getBoundingClientRect();
      mx = e.clientX - r.left; my = e.clientY - r.top;
    });
    card.addEventListener('mouseleave', () => {
      cancelAnimationFrame(raf);
      ctx!.clearRect(0, 0, w, h);
      mx = my = -9999;
    });
  });
</script>
