---
import Icon from './Icon.astro';

interface Props {
  homeHref: string;
  crumbDefault: string;
  /** Segmento intermedio opcional (e.g. las páginas ADR anidan bajo "Caso de estudio"). */
  parentCrumb?: { label: string; href: string };
  /** Solo la instancia mobile los necesita: el script del scroll-spy lee el id para
   *  encontrar el crumb y `sections` (vía data-attribute) para saber qué trackear. */
  id?: string;
  sections?: { id: string; label: string }[];
}
const { homeHref, crumbDefault, parentCrumb, id, sections } = Astro.props;
---

<span class="flex items-center text-xs font-mono uppercase tracking-widest">
  <a href={homeHref} class="text-ink-dim hover:text-ink transition-colors">JPA_</a>
  <Icon name="chevron-right" class="w-3 h-3 text-accent-blue mx-1.5" />
  {parentCrumb && (
    <>
      <a href={parentCrumb.href} class="text-ink-dim hover:text-ink transition-colors">{parentCrumb.label}</a>
      <Icon name="chevron-right" class="w-3 h-3 text-accent-blue mx-1.5" />
    </>
  )}
  <span id={id} data-sections={sections ? JSON.stringify(sections) : undefined} class="nav-crumb text-ink">{crumbDefault}</span>
</span>
