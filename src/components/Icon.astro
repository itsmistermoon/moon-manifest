---
import { icons, type IconName } from '../lib/icons';

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className } = Astro.props;
const icon = icons[name];
const strokeAttrs = icon.kind === 'stroke' ? { fill: 'none', stroke: 'currentColor', 'stroke-width': '2', 'stroke-linecap': 'round', 'stroke-linejoin': 'round' } : { fill: 'currentColor' };
---

<svg class={className} viewBox={icon.viewBox} aria-hidden="true" {...strokeAttrs} set:html={icon.inner} />
