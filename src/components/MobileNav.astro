---
import Icon from './Icon.astro';
import CornerBox from './CornerBox.astro';
import Breadcrumb from './Breadcrumb.astro';
// Mobile-only header nav: fixed top bar acting as a breadcrumb, hamburger→X trigger,
// dimmed backdrop, dropdown clamped to the page's own content width (corner-box, crosshairs).
//
// `sections` (optional) enables scroll-spy: the breadcrumb and the matching mobile-panel
// link track the in-page anchor currently in view. Pages with no in-page anchors (CV, case
// study) omit it and get a static crumb instead. `syncSidebarNav` additionally opts a page's
// own #sidebar-nav into that same spy — sidebar tracking lives here instead of in each page's
// own script since it only ever runs alongside this component's spy.
interface NavSection {
  id: string;
  label: string;
}
interface NavLink {
  href: string;
  label: string;
  current?: boolean;
}
interface Props {
  crumbDefault: string;
  sections?: NavSection[];
  links: NavLink[];
  menuLabel?: string;
  /** Must match the host page's own content-container width class, so the dropdown lines up with the containers below it. */
  maxWidth: string;
  /** Renders the ES/EN switcher in one fixed spot site-wide: top-right on desktop, last row of the mobile panel. */
  lang: { es: string; en: string; current: 'es' | 'en' };
  /** Where the "JPA_" breadcrumb root links to — the current locale's homepage. */
  homeHref: string;
  /** Optional middle breadcrumb segment — the page this one nests under (e.g. sections nest
      under "Inicio", ADRs nest under "Caso de estudio"). Renders as "JPA_ › {parentCrumb.label} › {crumbDefault}". */
  parentCrumb?: { label: string; href: string };
  /** Breakpoint donde la barra pasa de hamburger a breadcrumb+switcher (default 'md').
      El home usa 'lg': bajo 1024px su sidebar de dos columnas cae de los 300px mínimos y se rompe. */
  breakpoint?: 'md' | 'lg';
  /** Si la página renderiza su propio #sidebar-nav (hoy solo HomeTemplate), el scroll-spy
   *  también le sincroniza el estado activo. Opt-in explícito en vez de un querySelector
   *  incondicional buscando un id que la mayoría de las páginas no tiene. */
  syncSidebarNav?: boolean;
}

const { crumbDefault, sections = [], links, menuLabel = 'Abrir menú', maxWidth, lang, homeHref, parentCrumb, breakpoint = 'md', syncSidebarNav = false } = Astro.props;
// Tailwind necesita los nombres de clase completos y estáticos — no se pueden interpolar prefijos.
const bpDesktop = breakpoint === 'lg' ? 'hidden lg:block' : 'hidden md:block';
const bpMobile = breakpoint === 'lg' ? 'lg:hidden' : 'md:hidden';
const hasSections = sections.length > 0;
// Índice corrido para el stagger del fade-in (fila "Inicio" → secciones anidadas → resto de links).
const rowDelay = (i: number) => `${i * 20}ms`;

// Las secciones son sub-páginas del inicio, no hermanas de "Inicio"/"Caso de estudio"/"CV" —
// se anidan bajo el primer link (siempre "Inicio", por convención de cada página que llama
// a este componente). Sin sections (CV, caso de estudio), la lista queda plana como antes.
type Row =
  | { kind: 'link'; href: string; label: string; current?: boolean }
  | { kind: 'section'; href: string; id: string; label: string };

const rows: Row[] = hasSections
  ? [
      { kind: 'link', href: links[0].href, label: links[0].label, current: links[0].current },
      ...sections.map((s): Row => ({ kind: 'section', href: `#${s.id}`, id: s.id, label: s.label })),
      ...links.slice(1).map((l): Row => ({ kind: 'link', href: l.href, label: l.label, current: l.current })),
    ]
  : links.map((l): Row => ({ kind: 'link', href: l.href, label: l.label, current: l.current }));
---

<!-- Desktop: misma barra fija de 72px que la versión mobile (fondo + línea inferior), con el
     breadcrumb a la izquierda y el switcher de idioma a la derecha, ambos dentro del mismo
     ancho máximo que el contenido de la página (prop maxWidth). En el breakpoint md la barra
     se convierte en la versión mobile (hamburger) sin cambiar de altura ni de fondo. -->
<div class={`${bpDesktop} fixed top-0 inset-x-0 z-40 bg-dark-bg border-b border-dark-line`}>
  <div class={`${maxWidth} mx-auto px-6 h-[72px] flex items-center justify-between text-xs font-mono`}>
    <Breadcrumb homeHref={homeHref} crumbDefault={crumbDefault} parentCrumb={parentCrumb} />
    <span class="flex items-center gap-3">
      {lang.current === 'es' ? <span class="text-accent-yellow">ES</span> : <a href={lang.es} class="text-ink-dim hover:text-ink-muted transition-colors">ES</a>}
      <span class="text-dark-border">|</span>
      {lang.current === 'en' ? <span class="text-accent-yellow">EN</span> : <a href={lang.en} class="text-ink-dim hover:text-ink-muted transition-colors">EN</a>}
    </span>
  </div>
</div>

<div class={`${bpMobile} fixed top-0 inset-x-0 z-50 bg-dark-bg border-b border-dark-line`}>
  <div class="flex items-center justify-between px-6 h-[72px]">
    <Breadcrumb homeHref={homeHref} crumbDefault={crumbDefault} parentCrumb={parentCrumb} id="mobile-nav-crumb" sections={sections} />
    <button id="mobile-nav-toggle" aria-label={menuLabel} aria-expanded="false" class="relative w-11 h-11 -mr-3 flex items-center justify-center text-ink-muted hover:text-ink transition-colors">
      <span class="sr-only">{menuLabel}</span>
      <span id="mobile-nav-bar1" class="absolute w-[18px] h-[1.5px] bg-current transition-transform duration-200 ease-[ease] -translate-y-[4px]"></span>
      <span id="mobile-nav-bar2" class="absolute w-[18px] h-[1.5px] bg-current transition-transform duration-200 ease-[ease] translate-y-[4px]"></span>
    </button>
  </div>
</div>

<div id="mobile-nav-backdrop" class={`${bpMobile} fixed inset-0 z-40 bg-black/60 opacity-0 pointer-events-none transition-opacity duration-200 ease-[ease]`}></div>

<div id="mobile-nav-panel" class={`${bpMobile} fixed top-[72px] inset-x-0 z-[45] bg-dark-bg grid grid-rows-[0fr] pointer-events-none transition-[grid-template-rows] duration-200 ease-[ease]`}>
  <div class="overflow-hidden">
    <!-- Sin línea propia arriba: la barra superior ya tiene su border-b justo en este
         borde. z-45 (entre el backdrop en 40 y la barra en 50) garantiza que ese borde siempre
         se pinte encima del panel — con z-index igual, un solape de subpixel entre
         dos elementos fixed independientes hacía que el fondo del panel (mismo color
         que la barra) tapara la línea por completo en algunos navegadores. -->
    <div class={`${maxWidth} mx-auto px-6`}>
      <CornerBox class="mobile-nav-corner-box bg-dark-bg">
        {rows.map((r, i) => (
          r.kind === 'section' ? (
            <a href={r.href} data-section={r.id} style={`transition-delay:${rowDelay(i)}`} class={`mobile-nav-link nav-reveal flex items-center gap-2 pl-8 pr-4 h-[72px] text-xs font-mono uppercase tracking-widest text-ink-dim hover:text-ink hover:bg-dark-hover transition-colors ${i > 0 ? 'border-t border-dark-line' : ''}`}>
              <Icon name="chevron-right" class="w-3 h-3 text-accent-blue shrink-0" />
              {r.label}
            </a>
          ) : (
            <a href={r.href} style={`transition-delay:${rowDelay(i)}`} class={`mobile-nav-link nav-reveal flex items-center px-4 h-[72px] text-xs font-mono uppercase tracking-widest transition-colors hover:bg-dark-hover ${r.current ? 'text-ink' : 'text-ink-dim hover:text-ink'} ${i > 0 ? 'border-t border-dark-line' : ''}`}>{r.label}</a>
          )
        ))}
        <div class="grid grid-cols-2 h-[72px] text-xs font-mono border-t border-dark-line">
          {lang.current === 'es'
            ? <span class="nav-reveal flex items-center justify-center text-accent-yellow border-r border-dark-line" style={`transition-delay:${rowDelay(rows.length)}`}>ESPAÑOL</span>
            : <a href={lang.es} class="mobile-nav-link nav-reveal flex items-center justify-center text-ink-dim hover:text-ink hover:bg-dark-hover transition-colors border-r border-dark-line" style={`transition-delay:${rowDelay(rows.length)}`}>ESPAÑOL</a>}
          {lang.current === 'en'
            ? <span class="nav-reveal flex items-center justify-center text-accent-yellow" style={`transition-delay:${rowDelay(rows.length + 1)}`}>ENGLISH</span>
            : <a href={lang.en} class="mobile-nav-link nav-reveal flex items-center justify-center text-ink-dim hover:text-ink hover:bg-dark-hover transition-colors" style={`transition-delay:${rowDelay(rows.length + 1)}`}>ENGLISH</a>}
        </div>
      </CornerBox>
    </div>
    <div class="border-b border-dark-line"></div>
  </div>
</div>

<style>
  /* :global — CornerBox.astro renders this element from a different component,
     so it never carries MobileNav's own scope attribute. */
  :global(.mobile-nav-corner-box) {
    border-top: none;
    border-bottom: none;
  }

  .nav-reveal {
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 150ms ease-out, transform 150ms ease-out, color 150ms ease-out;
  }
  #mobile-nav-panel.nav-open .nav-reveal {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script define:vars={{ syncSidebarNav }}>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');
  const backdrop = document.getElementById('mobile-nav-backdrop');
  const bar1 = document.getElementById('mobile-nav-bar1');
  const bar2 = document.getElementById('mobile-nav-bar2');
  const links = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

  function toggleNav(open?: boolean) {
    const willOpen = open ?? panel?.classList.contains('pointer-events-none');
    toggle?.setAttribute('aria-expanded', String(willOpen));
    panel?.classList.toggle('grid-rows-[0fr]', !willOpen);
    panel?.classList.toggle('grid-rows-[1fr]', willOpen);
    panel?.classList.toggle('nav-open', willOpen);
    panel?.classList.toggle('pointer-events-none', !willOpen);
    backdrop?.classList.toggle('opacity-0', !willOpen);
    backdrop?.classList.toggle('pointer-events-none', !willOpen);
    // hamburger (two bars, offset apart) → X (both bars centered, rotated to cross)
    bar1?.classList.toggle('-translate-y-[4px]', !willOpen);
    bar1?.classList.toggle('translate-y-0', willOpen);
    bar1?.classList.toggle('rotate-45', willOpen);
    bar2?.classList.toggle('translate-y-[4px]', !willOpen);
    bar2?.classList.toggle('translate-y-0', willOpen);
    bar2?.classList.toggle('-rotate-45', willOpen);
  }
  toggle?.addEventListener('click', () => toggleNav());
  backdrop?.addEventListener('click', () => toggleNav(false));
  links.forEach(l => l.addEventListener('click', () => toggleNav(false)));

  // Scroll-spy breadcrumb — only wired up when the page passed `sections`.
  // `sections` viaja en el data-attribute del crumb mobile; el spy actualiza
  // todos los .nav-crumb (mobile y desktop) a la vez.
  const crumbData = document.getElementById('mobile-nav-crumb');
  const crumbEls = document.querySelectorAll<HTMLElement>('.nav-crumb');
  const sections: { id: string; label: string }[] = crumbData ? JSON.parse(crumbData.dataset.sections || '[]') : [];
  if (crumbEls.length && sections.length) {
    const crumbLabels = Object.fromEntries(sections.map(s => [s.id, s.label]));
    const sectionEls = sections
      .map(s => document.getElementById(s.id))
      .filter((el): el is HTMLElement => el !== null);
    // Only the section links track scroll position — global nav links (Inicio/CV/...)
    // and the language switcher keep whatever active/inactive state they were rendered with.
    const sectionLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link[data-section]');
    // Desktop sidebar nav (#sidebar-nav, rendered by the page itself) tracks the same
    // sections — driven from here instead of a second observer in the page's own script.
    // Opt-in via `syncSidebarNav`, set by whichever page actually renders that DOM.
    const sidebarLinks = syncSidebarNav
      ? document.querySelectorAll<HTMLAnchorElement>('#sidebar-nav a')
      : [];
    const spy = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && crumbLabels[entry.target.id]) {
          crumbEls.forEach(el => { el.textContent = crumbLabels[entry.target.id]; });
          sectionLinks.forEach(l => {
            const isActive = l.dataset.section === entry.target.id;
            l.classList.toggle('text-ink', isActive);
            l.classList.toggle('text-ink-dim', !isActive);
          });
          sidebarLinks.forEach(l => {
            l.classList.toggle('active', l.getAttribute('href') === `#${entry.target.id}`);
          });
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });
    sectionEls.forEach(el => spy.observe(el));
  }
</script>
