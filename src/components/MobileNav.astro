---
// Mobile-only header nav: fixed top bar acting as a breadcrumb, hamburger→X trigger,
// dimmed backdrop, dropdown clamped to the page's own content width (corner-box, crosshairs).
//
// `sections` (optional) enables scroll-spy: the breadcrumb, the matching mobile-panel link,
// and the desktop #sidebar-nav link (if present on the page) all track the in-page anchor
// currently in view. Pages with no in-page anchors (CV, case study) omit it and get a
// static crumb instead — this is also why sidebar-nav tracking lives here instead of in
// each page's own script: it only ever runs alongside this component's own spy.
interface NavSection {
  id: string;
  label: string;
}
interface NavLink {
  href: string;
  label: string;
  current?: boolean;
}
interface Props {
  crumbDefault: string;
  sections?: NavSection[];
  links: NavLink[];
  menuLabel?: string;
  /** Must match the host page's own content-container width class, so the dropdown lines up with the containers below it. */
  maxWidth: string;
  /** Renders the ES/EN switcher in one fixed spot site-wide: top-right on desktop, last row of the mobile panel. */
  lang: { es: string; en: string; current: 'es' | 'en' };
  /** Where the "JPA_" breadcrumb root links to — the current locale's homepage. */
  homeHref: string;
}

const { crumbDefault, sections = [], links, menuLabel = 'Abrir menú', maxWidth, lang, homeHref } = Astro.props;
const hasSections = sections.length > 0;
---

<!-- Desktop: fixed top-right, identical position on every page regardless of that page's own layout -->
<div class="hidden md:flex fixed top-6 right-6 z-40 items-center gap-3 text-xs font-mono">
  {lang.current === 'es' ? <span class="text-accent-yellow">ES</span> : <a href={lang.es} class="text-ink-dim hover:text-ink-muted transition-colors">ES</a>}
  <span class="text-dark-border">|</span>
  {lang.current === 'en' ? <span class="text-accent-yellow">EN</span> : <a href={lang.en} class="text-ink-dim hover:text-ink-muted transition-colors">EN</a>}
</div>

<div class="md:hidden fixed top-0 inset-x-0 z-50 bg-dark-bg border-b border-dark-line">
  <div class="flex items-center justify-between px-6 h-14">
    <span class="flex items-center text-xs font-mono uppercase tracking-widest">
      <a href={homeHref} class="text-ink-dim hover:text-ink transition-colors">JPA_</a>
      <svg class="w-3 h-3 text-accent-blue mx-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
      <span id="mobile-nav-crumb" data-sections={JSON.stringify(sections)} class="text-ink">{crumbDefault}</span>
    </span>
    <button id="mobile-nav-toggle" aria-label={menuLabel} aria-expanded="false" class="relative w-11 h-11 -mr-3 flex items-center justify-center text-ink-muted hover:text-ink transition-colors">
      <span class="sr-only">{menuLabel}</span>
      <span id="mobile-nav-bar1" class="absolute w-[18px] h-[1.5px] bg-current transition-transform duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] -translate-y-[4px]"></span>
      <span id="mobile-nav-bar2" class="absolute w-[18px] h-[1.5px] bg-current transition-transform duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-[4px]"></span>
    </button>
  </div>
</div>

<div id="mobile-nav-backdrop" class="md:hidden fixed inset-0 z-40 bg-black/60 opacity-0 pointer-events-none transition-opacity duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"></div>

<div id="mobile-nav-panel" class="md:hidden fixed top-14 inset-x-0 z-50 bg-dark-bg opacity-0 -translate-y-2 pointer-events-none transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]">
  <div class={`${maxWidth} mx-auto px-6`}>
    <div class="corner-box bg-dark-bg">
      <span class="c tl"></span><span class="c tr"></span><span class="c bl"></span><span class="c br"></span>
      {sections.map((s, i) => (
        <a href={`#${s.id}`} data-section={s.id} class={`mobile-nav-link block px-4 py-3 text-xs font-mono uppercase tracking-widest text-ink-dim hover:text-ink transition-colors ${i > 0 ? 'border-t border-dark-line' : ''}`}>{s.label}</a>
      ))}
      {links.map((l, i) => (
        <a href={l.href} class={`mobile-nav-link block px-4 py-3 text-xs font-mono uppercase tracking-widest transition-colors ${l.current ? 'text-ink' : 'text-ink-dim hover:text-ink'} ${i > 0 || hasSections ? 'border-t border-dark-line' : ''}`}>{l.label}</a>
      ))}
      <div class="flex items-center gap-3 px-4 py-3 text-xs font-mono border-t border-dark-line">
        {lang.current === 'es' ? <span class="text-accent-yellow">ES</span> : <a href={lang.es} class="mobile-nav-link text-ink-dim hover:text-ink transition-colors">ES</a>}
        <span class="text-dark-border">|</span>
        {lang.current === 'en' ? <span class="text-accent-yellow">EN</span> : <a href={lang.en} class="mobile-nav-link text-ink-dim hover:text-ink transition-colors">EN</a>}
      </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');
  const backdrop = document.getElementById('mobile-nav-backdrop');
  const bar1 = document.getElementById('mobile-nav-bar1');
  const bar2 = document.getElementById('mobile-nav-bar2');
  const links = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

  function toggleNav(open?: boolean) {
    const willOpen = open ?? panel?.classList.contains('pointer-events-none');
    toggle?.setAttribute('aria-expanded', String(willOpen));
    panel?.classList.toggle('opacity-0', !willOpen);
    panel?.classList.toggle('-translate-y-2', !willOpen);
    panel?.classList.toggle('pointer-events-none', !willOpen);
    backdrop?.classList.toggle('opacity-0', !willOpen);
    backdrop?.classList.toggle('pointer-events-none', !willOpen);
    // hamburger (two bars, offset apart) → X (both bars centered, rotated to cross)
    bar1?.classList.toggle('-translate-y-[4px]', !willOpen);
    bar1?.classList.toggle('translate-y-0', willOpen);
    bar1?.classList.toggle('rotate-45', willOpen);
    bar2?.classList.toggle('translate-y-[4px]', !willOpen);
    bar2?.classList.toggle('translate-y-0', willOpen);
    bar2?.classList.toggle('-rotate-45', willOpen);
  }
  toggle?.addEventListener('click', () => toggleNav());
  backdrop?.addEventListener('click', () => toggleNav(false));
  links.forEach(l => l.addEventListener('click', () => toggleNav(false)));

  // Scroll-spy breadcrumb — only wired up when the page passed `sections`
  const crumbEl = document.getElementById('mobile-nav-crumb');
  const sections: { id: string; label: string }[] = crumbEl ? JSON.parse(crumbEl.dataset.sections || '[]') : [];
  if (crumbEl && sections.length) {
    const crumbLabels = Object.fromEntries(sections.map(s => [s.id, s.label]));
    const sectionEls = sections
      .map(s => document.getElementById(s.id))
      .filter((el): el is HTMLElement => el !== null);
    // Only the section links track scroll position — global nav links (Inicio/CV/...)
    // and the language switcher keep whatever active/inactive state they were rendered with.
    const sectionLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link[data-section]');
    // Desktop sidebar nav (#sidebar-nav, rendered by the page itself) tracks the same
    // sections — driven from here instead of a second observer in the page's own script,
    // since the two only ever coexist on pages that also pass `sections`.
    const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('#sidebar-nav a');
    const spy = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && crumbLabels[entry.target.id]) {
          crumbEl.textContent = crumbLabels[entry.target.id];
          sectionLinks.forEach(l => {
            const isActive = l.dataset.section === entry.target.id;
            l.classList.toggle('text-ink', isActive);
            l.classList.toggle('text-ink-dim', !isActive);
          });
          sidebarLinks.forEach(l => {
            l.classList.toggle('active', l.getAttribute('href') === `#${entry.target.id}`);
          });
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });
    sectionEls.forEach(el => spy.observe(el));
  }
</script>
