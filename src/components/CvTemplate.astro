---
import BaseLayout from '../layouts/BaseLayout.astro';
import MobileNav from './MobileNav.astro';
import Icon from './Icon.astro';
import { cv, contact } from '../content/cv';
import { socialLinks } from '../content/home';
import { routes, type Locale } from '../lib/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = cv[locale];
const homeHref = routes.home[locale];
const cvHref = routes.cv[locale];
const proyectoHref = routes.proyecto[locale];
---

<BaseLayout title={t.title}>
  <MobileNav
    maxWidth="max-w-4xl"
    lang={{ es: routes.cv.es, en: routes.cv.en, current: locale }}
    homeHref={homeHref}
    crumbDefault="CV"
    menuLabel={locale === 'en' ? 'Open menu' : undefined}
    links={[
      { href: homeHref, label: t.navLinks.home },
      { href: proyectoHref, label: t.navLinks.proyecto },
      { href: cvHref, label: t.navLinks.cv, current: true },
    ]}
  />
  <!-- max-md:pt-[120px] = barra fija de MobileNav (72px, altura propia del componente) + el padding-top original en mobile (py-12, 48px) -->
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-24 max-md:pt-[120px]">

    <header class="mb-12">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-ink mb-2 leading-[1.1]">
            {t.name}
          </h1>
          <p class="text-xl text-accent-blue font-medium">{t.tagline}</p>
        </div>
        <a href={`${cvHref}.pdf`} download class="inline-flex items-center px-5 py-2.5 bg-accent-yellow hover:bg-accent-yellow-light text-black font-semibold text-sm transition-colors shrink-0">
          <Icon name="file-text" class="w-4 h-4 mr-2" />
          {t.downloadPdf}
        </a>
      </div>

      <div class="flex flex-wrap gap-4 text-sm text-ink-muted">
        <span class="flex items-center">
          <Icon name="map-pin" class="w-4 h-4 mr-2 text-ink-dim" />
          {contact.location}
        </span>
        <span class="flex items-center">
          <Icon name="phone" class="w-4 h-4 mr-2 text-ink-dim" />
          {contact.phone}
        </span>
        <a href={`mailto:${contact.email}`} class="flex items-center hover:text-accent-blue transition-colors">
          <Icon name="mail" class="w-4 h-4 mr-2 text-ink-dim" />
          {contact.email}
        </a>
      </div>
    </header>

    <div class="space-y-12">

      <section>
        <h2 class="section-label">{t.sections.profile}</h2>
        <p class="text-ink-muted leading-relaxed text-base">
          {t.profile}
        </p>
      </section>

      <section>
        <h2 class="section-label">{t.sections.project}</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
        <div class="brutalist-card border-0 p-6 md:p-8">
          <h3 class="text-2xl font-display font-bold text-ink mb-2">{t.project.title}</h3>
          <p class="text-accent-blue font-medium text-sm mb-4">{t.project.subtitle}</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">{t.project.labels.backend}</span>
              <p class="text-ink-muted">{t.project.backend}</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">{t.project.labels.frontend}</span>
              <p class="text-ink-muted">{t.project.frontend}</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">{t.project.labels.awsServices}</span>
              <p class="text-ink-muted">{t.project.awsServices}</p>
            </div>
            <div>
              <span class="text-ink-dim text-xs font-mono uppercase">{t.project.labels.devops}</span>
              <p class="text-ink-muted">{t.project.devops}</p>
            </div>
          </div>
          <div class="mt-4">
            <span class="text-ink-dim text-xs font-mono uppercase">{t.project.labels.architecture}</span>
            <p class="text-ink-muted">{t.project.architecture}</p>
          </div>
          <div class="mt-6 pt-4 border-t border-dark-border flex flex-wrap gap-5 items-center">
            <a href={proyectoHref} class="inline-flex items-center text-sm font-semibold text-accent-blue hover:text-ink transition-colors">
              {t.project.viewCaseStudy}
              <Icon name="arrow-right" class="w-4 h-4 ml-2" />
            </a>
            <a href={socialLinks.platform} target="_blank" rel="noopener" class="inline-flex items-center text-sm font-medium text-accent-yellow hover:text-yellow-300 transition-colors">
              {t.project.viewPlatform}
              <Icon name="external-link" class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
        </div>
      </section>

      <section>
        <h2 class="section-label">{t.sections.experience}</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          {t.experience.map((exp, i) => (
            <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-ink group-hover:text-accent-blue transition-colors">{exp.role}</h3>
                <span class="text-xs font-mono text-ink-dim mt-1 sm:mt-0">{exp.period}</span>
              </div>
              <p class="text-ink-muted text-sm mb-3">{exp.company}{exp.location && ` · ${exp.location}`}</p>
              <ul class="space-y-1.5">
                {exp.bullets.map((bullet) => (
                  <li class="text-ink-muted text-sm leading-relaxed flex gap-2">
                    <span class="text-dark-border mt-1.5 shrink-0">—</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-label">{t.sections.education}</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          {t.education.map((edu, i) => (
            <div class={`brutalist-card p-5 border-0 ${i > 0 ? 'border-t border-dark-border' : ''} group`}>
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
                <h3 class="text-lg font-semibold text-ink group-hover:text-accent-blue transition-colors">{edu.title}</h3>
                <span class="text-xs font-mono text-ink-dim mt-1 sm:mt-0">{edu.period}</span>
              </div>
              <p class="text-ink-muted text-sm mb-3">{edu.institution}{edu.location && ` · ${edu.location}`}</p>
              <p class="text-ink-muted text-sm leading-relaxed">{edu.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-label">{t.sections.skills}</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <span class="c tm"></span><span class="c bm"></span>
          <div class="grid grid-cols-1 md:grid-cols-2">
          {t.skills.map((skill, i) => {
            const isSecondCol = i % 2 === 1;
            const isThirdRow = i >= 2;
            return (
              <div class={`brutalist-card p-5 border-0 ${isSecondCol ? 'md:border-l border-dark-border' : ''} ${isThirdRow ? 'border-t border-dark-border' : ''} group`}>
                <h4 class="text-ink font-semibold mb-3 text-base group-hover:text-accent-blue transition-colors">{skill.category}</h4>
                <div class="flex flex-wrap gap-1.5">
                  {skill.items.map((item) => (
                    <span class="px-2.5 py-1 text-xs font-mono text-ink-muted bg-dark-bg border border-dark-border">{item}</span>
                  ))}
                </div>
              </div>
            );
          })}
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-label">{t.sections.language}</h2>
        <div class="corner-box">
          <span class="c tl"></span><span class="c tr"></span>
          <span class="c bl"></span><span class="c br"></span>
          <div class="brutalist-card border-0 p-5 group">
            <div class="flex items-center justify-between">
              <div>
                <h4 class="text-ink font-semibold mb-1 group-hover:text-accent-blue transition-colors">{t.language.title}</h4>
                <p class="text-ink-muted text-sm">{t.language.level}</p>
              </div>
              <span class="text-xs font-mono text-accent-yellow border border-accent-yellow/20 px-2 py-1">{t.language.badge}</span>
            </div>
          </div>
        </div>
      </section>

    </div>

  </div>
</BaseLayout>
